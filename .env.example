# Database
POSTGRES_USER=wijnpick
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=wijnpick
DATABASE_URL=postgresql://wijnpick:changeme_in_production@db:5432/wijnpick

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Backend
SECRET_KEY=changeme_in_production
MATCH_THRESHOLD=0.75
UPLOAD_DIR=/app/uploads

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Initial admin user (seeded on first startup when no users exist)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme_in_production
ADMIN_EMAIL=admin@wijnpick.local

# CORS — comma-separated origins, or "*" for development
CORS_ORIGINS=*

# DuckDNS (for deployment)
DUCKDNS_DOMAIN=your-subdomain
DUCKDNS_TOKEN=your-duckdns-token
