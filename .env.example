# Database
POSTGRES_USER=wijnpick
POSTGRES_PASSWORD=<generate-a-strong-password>
POSTGRES_DB=wijnpick
DATABASE_URL=postgresql://wijnpick:<generate-a-strong-password>@db:5432/wijnpick

# Google Gemini
GEMINI_API_KEY=<your-gemini-api-key>
GEMINI_VISION_MODEL=gemini-2.5-flash
GEMINI_EXTRACTION_MODEL=gemini-2.5-pro
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Backend
SECRET_KEY=<generate-a-random-secret>
MATCH_THRESHOLD=0.80
UPLOAD_DIR=/app/uploads

# Auth — password for the auto-created admin account
# Both SECRET_KEY and ADMIN_PASSWORD are REQUIRED — the app will refuse to start without them.
ADMIN_PASSWORD=<choose-a-strong-admin-password>
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Storage backend ("local" or "s3") — local stores files on disk, s3 uses any S3-compatible service
STORAGE_BACKEND=local
# S3 settings (only needed when STORAGE_BACKEND=s3)
# For OCI Object Storage, use: https://<namespace>.compat.objectstorage.<region>.oraclecloud.com
S3_ENDPOINT_URL=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=
S3_PRESIGNED_URL_EXPIRY=3600

# Kafka (event logging)
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Langfuse (LLM observability) — leave empty to disable
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Sentry (error tracking) — leave empty to disable
SENTRY_DSN=
VITE_SENTRY_DSN=

# Domain (for deployment — Caddy handles HTTPS automatically)
DOMAIN=dockscan.nl
