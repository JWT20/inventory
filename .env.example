# Database
POSTGRES_USER=wijnpick
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=wijnpick
DATABASE_URL=postgresql://wijnpick:changeme_in_production@db:5432/wijnpick

# Gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_VISION_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Backend
SECRET_KEY=changeme_in_production
MATCH_THRESHOLD=0.92
UPLOAD_DIR=/app/uploads

# Auth — password for the auto-created admin account
ADMIN_PASSWORD=changeme_in_production
TOKEN_EXPIRE_DAYS=90

# Kafka (event logging)
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Domain (for deployment)
DOMAIN=dockscan.nl
