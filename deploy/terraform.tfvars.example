# Oracle Cloud Infrastructure - pas deze waarden aan
tenancy_ocid     = "ocid1.tenancy.oc1..your-tenancy-ocid"
user_ocid        = "ocid1.user.oc1..your-user-ocid"
fingerprint      = "your:api:key:fingerprint"
private_key_path = "/Users/Gebruiker/.oci/oci_api_key.pem"
region           = "eu-amsterdam-1"

# Compartment (gebruik tenancy OCID voor root compartment)
compartment_ocid = "ocid1.tenancy.oc1..your-tenancy-ocid"

# SSH key voor VM toegang
ssh_public_key_path = "/Users/Gebruiker/.ssh/id_rsa.pub"

# DuckDNS
duckdns_domain = "your-wijnpick"
duckdns_token  = "your-duckdns-token"

# OpenAI
openai_api_key = "sk-your-openai-api-key"
