# Copy to terraform.tfvars (gitignored) and fill in real values.
# Get these from the Contabo Customer Control Panel -> Account -> API.
# NEVER commit terraform.tfvars or paste these values in chat / issues / PRs.

contabo_oauth2_client_id     = "INT-xxxxxxxx"
contabo_oauth2_client_secret = "your-client-secret-here"
contabo_oauth2_user          = "your-api-email@example.com"
contabo_oauth2_pass          = "your-api-password"
