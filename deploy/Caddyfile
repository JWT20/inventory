${DOMAIN} {
    log {
        output file /var/log/caddy/access.log {
            roll_size 50mb
            roll_keep 10
            roll_keep_for 720h
        }
        format json
    }

    # Backend API
    handle /api/* {
        reverse_proxy localhost:8000
    }

    # Frontend (React SPA)
    handle {
        reverse_proxy localhost:3000
    }
}
